{
    "name": "The 8th Layer Theme",
    "colors": {
        "editor.background": "#0b3f2a",
        "editor.foreground": "#d4c4b7",
        "editorCursor.foreground": "#f2b86a",
        "editorCursor.background": "#0b3f2a",
        
        /* التعديلات الخاصة بالتحديد الذهبي */
        "editor.selectionBackground": "#f2b86a40",
        "editor.selectionHighlightBackground": "#f2b86a30",
        "editor.inactiveSelectionBackground": "#f2b86a20",
        
        "editor.lineHighlightBackground": "#f2b86a15",
        "editor.lineHighlightBorder": "#00000000",
        
        "input.background": "#082d1e",
        "input.foreground": "#f2b86a",
        "input.placeholderForeground": "#f2b86a80",
        
        "sideBar.background": "#082d1e",
        "sideBarSectionHeader.background": "#052215",
        "sideBarSectionHeader.foreground": "#f2b86a",
        
        "activityBar.background": "#052215",
        "activityBar.foreground": "#f2b86a",
        "activityBar.inactiveForeground": "#f2b86a80",
        
        "titleBar.activeBackground": "#052215",
        "titleBar.inactiveBackground": "#052215",
        "titleBar.activeForeground": "#f2b86a",
        
        "statusBar.background": "#052215",
        "statusBar.noFolderBackground": "#052215",
        "statusBar.foreground": "#f2b86a",
        
        "tab.activeBackground": "#0b3f2a",
        "tab.activeForeground": "#f2b86a",
        "tab.inactiveBackground": "#082d1e",
        "tab.inactiveForeground": "#f2b86a80",
        "editorGroupHeader.tabsBackground": "#052215",
        
        "panel.background": "#082d1e",
        "terminal.background": "#0b3f2a",
        
        "minimap.background": "#0b3f2a",
        
        "breadcrumb.background": "#0b3f2a",
        "breadcrumb.foreground": "#f2b86a",
        
        "menu.background": "#082d1e",
        "menu.foreground": "#f2b86a",

        "editorWidget.background": "#082d1e",
        "editorWidget.foreground": "#f2b86a",
        "editorWidget.border": "#052215",
        
        "chat.requestBackground": "#052215",
        "chat.requestBorder": "#082d1e",
        
        "list.activeSelectionBackground": "#0b3f2a",
        "list.hoverBackground": "#052215",
        "list.inactiveSelectionBackground": "#052215",

        "welcomePage.tileBackground": "#082d1e",
        "welcomePage.tileHoverBackground": "#052215",
        "welcomePage.tileBorder": "#052215",
        
        "textLink.foreground": "#f2b86a",
        "textLink.activeForeground": "#dfc57b",
        
        "progressBar.background": "#f2b86a",
        "button.background": "#082d1e",
        "button.foreground": "#f2b86a",
        "button.hoverBackground": "#052215"
    },
    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#6a997d"
            }
        },
        {
            "name": "Punctuation & Brackets",
            "scope": [
                "punctuation",
                "meta.brace",
                "punctuation.definition.tag",
                "punctuation.definition.tag.html",
                "punctuation.definition.tag.begin.html",
                "punctuation.definition.tag.end.html",
                "punctuation.separator",
                "punctuation.terminator",
                "punctuation.section.embedded"
            ],
            "settings": {
                "foreground": "#6a997d"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "string constant.other.placeholder"
            ],
            "settings": {
                "foreground": "#d4c4b7"
            }
        },
        {
            "name": "Colors",
            "scope": [
                "constant.other.color"
            ],
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "name": "Invalid",
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#ff5c5c"
            }
        },
        {
            "name": "Keyword, Storage",
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier",
                "keyword.control"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "Tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml",
                "markup.deleted.git_gutter",
                "support.class.component"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "Attributes",
            "scope": [
                "entity.other.attribute-name",
                "text.html.basic entity.other.attribute-name.html",
                "text.html.basic entity.other.attribute-name"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#dfc57b"
            }
        },
        {
            "name": "Function, Special Method",
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "variable.function",
                "support.function",
                "keyword.other.special-method",
                "meta.method.declaration"
            ],
            "settings": {
                "foreground": "#dfc57b"
            }
        },
        {
            "name": "Block Level Variables",
            "scope": [
                "meta.block variable.other"
            ],
            "settings": {
                "foreground": "#d4c4b7"
            }
        },
        {
            "name": "Other Variable, String Link",
            "scope": [
                "support.other.variable",
                "string.other.link"
            ],
            "settings": {
                "foreground": "#d4c4b7"
            }
        },
        {
            "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
            "scope": [
                "constant.numeric",
                "constant.language",
                "support.constant",
                "constant.character",
                "constant.escape",
                "variable.parameter",
                "keyword.other.unit",
                "keyword.other",
                "keyword.other.doctype",
                "meta.tag.sgml.doctype",
                "punctuation.definition.doctype"
            ],
            "settings": {
                "foreground": "#d98e73"
            }
        },
        {
            "name": "String, Symbols, Inherited Class, Markup Heading",
            "scope": [
                "string",
                "string.quoted",
                "string.template",
                "constant.other.symbol",
                "constant.other.key",
                "entity.other.inherited-class",
                "markup.heading",
                "markup.inserted.git_gutter",
                "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js",
                "markup.inline.raw"
            ],
            "settings": {
                "foreground": "#b4d3b2"
            }
        },
        {
            "name": "Class, Support",
            "scope": [
                "entity.name",
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class",
                "support.other.namespace.use.php",
                "meta.use.php",
                "support.other.namespace.php",
                "markup.changed.git_gutter",
                "support.type.sys-types"
            ],
            "settings": {
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "CSS Classes",
            "scope": [
                "entity.other.attribute-name.class"
            ],
            "settings": {
                "foreground": "#dfc57b"
            }
        },
        {
            "name": "CSS ID's",
            "scope": [
                "source.sass keyword.control"
            ],
            "settings": {
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "Inserted",
            "scope": [
                "markup.inserted"
            ],
            "settings": {
                "foreground": "#b4d3b2"
            }
        },
        {
            "name": "Deleted",
            "scope": [
                "markup.deleted"
            ],
            "settings": {
                "foreground": "#ff5c5c"
            }
        },
        {
            "name": "Changed",
            "scope": [
                "markup.changed"
            ],
            "settings": {
                "foreground": "#dfc57b"
            }
        },
        {
            "name": "Regular Expressions",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "Escape Characters",
            "scope": [
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "URL",
            "scope": [
                "*url*",
                "*link*",
                "*uri*"
            ],
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "name": "Decorators",
            "scope": [
                "tag.decorator.js entity.name.tag.js",
                "tag.decorator.js punctuation.definition.tag.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "ES7 Bind Operator",
            "scope": [
                "source.js constant.other.object.key.js string.unquoted.label.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#f2b86a"
            }
        },
        {
            "name": "JSON Key - Level 0",
            "scope": [
                "source.json meta.structure.dictionary.json support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#dfc57b"
            }
        },
        {
